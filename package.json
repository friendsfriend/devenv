{
  "name": "devenv-cli",
  "version": "0.12.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/friendsfriend/devenv.git"
  },
  "description": "DevEnv - Development Environment CLI with embedded Go server",
  "engines": {
    "bun": ">=1.3.14",
    "go": ">=1.26.4"
  },
  "license": "PROPRIETARY",
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "bun run build.ts",
    "build:single": "bun run build.ts --single",
    "set-version": "bun run scripts/set-version.ts",
    "perf:fixture": "bun run scripts/create-perf-config.ts",
    "install:bin": "sh install.sh",
    "dev": "cd tui && bun run dev",
    "type-check": "cd tui && bun run type-check",
    "test": "cd tui && bun run test",
    "test:server": "cd server && go test ./...",
    "vet:server": "cd server && go vet ./...",
    "verify": "bun run type-check && bun run test && bun run test:server && bun run vet:server"
  }
}
