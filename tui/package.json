{
  "name": "devenv",
  "version": "0.12.7",
  "description": "DevEnv - Development Environment TUI",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "devenv": "./bin/devenv"
  },
  "scripts": {
    "dev": "bun run packages/cli/src/spawn.ts",
    "build": "bun run scripts/build.ts",
    "type-check": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@opentui/core": "0.4.2",
    "@opentui/keymap": "0.4.2",
    "@opentui/solid": "0.4.2"
  },
  "knip": {
    "ignoreBinaries": [
      "clip",
      "go",
      "pbcopy",
      "pbpaste",
      "powershell",
      "xclip",
      "xsel"
    ]
  }
}
